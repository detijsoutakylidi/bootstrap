{
    // window — chrome, title bar, window behavior
    "window.newWindowDimensions": "inherit",
    "window.nativeFullScreen": false,
    "window.customTitleBarVisibility": "never",
    // "window.titleBarStyle": "custom",
    // "window.title": "${dirty} ${activeEditorShort}${separator}${rootName}${separator}${profileName}",
    // "window.title": "${dirty} ${activeEditorShort}$ ${activeFolderMedium} | ${rootName}${separator}${profileName}",
    // "window.titleSeparator": " — ",

    // workbench — theme, layout, sidebar, tabs, panels
    "workbench.colorTheme": "Catppuccin Macchiato",
    "workbench.tips.enabled": false,
    "workbench.navigationControl.enabled": false,
    "workbench.layoutControl.enabled": false,
    "workbench.startupEditor": "none",
    "workbench.list.openMode": "singleClick",
    "workbench.sideBar.location": "right",
    "workbench.statusBar.visible": true,
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "workbench.editor.enablePreview": false,
    "workbench.editor.enablePreviewFromQuickOpen": false,
    "workbench.editor.showTabs": "multiple",
    "workbench.editor.empty.hint": "hidden",
    "chat.commandCenter.enabled": false,

    // explorer & search — file tree behavior, search scope
    "explorer.autoReveal": false,
    "explorer.confirmDragAndDrop": false,
    "search.useGlobalIgnoreFiles": true,
    "search.useParentIgnoreFiles": true,

    // problems — diagnostics panel visibility and decorations
    "problems.visibility": true,
    "problems.decorations.enabled": false,

    // editor — appearance, font, indentation, sticky scroll
    "editor.fontSize": 18,
    "editor.lineNumbers": "on",
    "editor.tabSize": 2,
    "editor.detectIndentation": false,
    "editor.copyWithSyntaxHighlighting": false,
    "editor.stickyScroll.enabled": false,
    "editor.colorDecorators": false,
    "editor.guides.indentation": false,
    // "editor.glyphMargin": false,

    // editor — minimap
    "editor.minimap.enabled": false,
    "editor.minimap.renderCharacters": false,
    "editor.minimap.size": "fit",
    "editor.minimap.showSlider": "always",

    // editor — brackets, auto-closing, matching
    "editor.bracketPairColorization.enabled": false,
    "editor.matchBrackets": "near",
    "editor.guides.bracketPairs": false,
    "editor.guides.bracketPairsHorizontal": "active",
    "editor.guides.highlightActiveBracketPair": true,
    "editor.autoClosingBrackets": "always",
    "editor.autoClosingComments": "always",
    "editor.autoClosingQuotes": "always",

    // editor — suggestions, hover, navigation, multi-cursor
    "editor.hover.enabled": "on",
    // "editor.hover.delay": 1000,
    "editor.quickSuggestions": {
      "other": "on",
      "comments": "on",
      "strings": "on"
    },
    "editor.multiCursorModifier": "ctrlCmd",
    "editor.inlayHints.enabled": "off",
    "editor.gotoLocation.multipleReferences": "goto",
    "editor.gotoLocation.multipleDefinitions": "goto",
    "editor.gotoLocation.multipleDeclarations": "goto",
    "editor.gotoLocation.multipleImplementations": "goto",
    "editor.gotoLocation.multipleTypeDefinitions": "goto",

    // silence the noise — disable visual clutter and distractions
    "breadcrumbs.enabled": false,
    "editor.lightbulb.enabled": "off",
    "editor.selectionHighlight": false,
    "editor.overviewRulerBorder": false,
    "editor.renderLineHighlight": "gutter",
    "editor.occurrencesHighlight": "off",
    "editor.renderControlCharacters": false,
    "editor.hideCursorInOverviewRuler": true,
    "notebook.diff.overviewRuler": false,

    // diff editor — inline vs side-by-side, whitespace
    "diffEditor.ignoreTrimWhitespace": true,
    "diffEditor.renderSideBySide": false,

    // scm & git — source control gutter, decorations
    "scm.diffDecorations": "all",
    "scm.diffDecorationsGutterVisibility": "always",
    "scm.diffDecorationsGutterWidth": 2,
    "git.decorations.enabled": false,

    // files — whitespace trimming, final newline
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,

    // terminal — integrated terminal settings
    "terminal.integrated.fontSize": 18,

    // security & telemetry — privacy, workspace trust, accessibility
    "telemetry.telemetryLevel": "off",
    "security.workspace.trust.untrustedFiles": "open",
    "security.promptForLocalFileProtocolHandling": false,
    "editor.accessibilitySupport": "off",
    "accessibility.signalOptions.volume": 0,

    // PHP — language-specific overrides
    "emmet.excludeLanguages": [
      "PHP"
    ],

    // extension — Intelephense
    "intelephense.environment.phpVersion": "8.2.0",
    // "intelephense.codeLens.references.enable": true,
    // "intelephense.codeLens.implementations.enable": true,
    // "intelephense.codeLens.overrides.enable": true,
    // "intelephense.codeLens.parent.enable": true,
    // "intelephense.codeLens.usages.enable": true,
    // "intelephense.diagnostics.memberAccess": true
    "intelephense.diagnostics.embeddedLanguages": true,
    "intelephense.completion.suggestObjectOperatorStaticMethods": false,
    // "intelephense.diagnostics.noMixedTypeCheck": false,
    // "intelephense.diagnostics.relaxedTypeCheck": false,

    // extension — Claude Code
    "claudeCode.preferredLocation": "panel",
    "claudeCode.enableNewConversationShortcut": false,
    "claudeCode.hideOnboarding": true,
    "claudeCode.useCtrlEnterToSend": false,
    "claudeCode.selectedModel": "default",

    // extension — Project Manager
    "projectManager.git.baseFolders": [
      "__PROJECTS_DIR__"
    ],
    "projectManager.showParentFolderInfoOnDuplicates": true,
    "projectManager.openInNewWindowWhenClickingInStatusBar": true,
    "projectManager.removeCurrentProjectFromList": false,
    "projectManager.tags": [
      "System",
      "DJTL"
    ],
    "projectManager.sortList": "Name",

    // json schemas — trusted domains for schema downloads
    "json.schemaDownload.trustedDomains": {
      "https://schemastore.azurewebsites.net/": true,
      "https://raw.githubusercontent.com/": true,
      "https://www.schemastore.org/": true,
      "https://json.schemastore.org/": true,
      "https://json-schema.org/": true,
      "https://esm.sh/gh/catppuccin/vscode%40catppuccin-vsc-v3.18.1/packages/catppuccin-vsc/schemas/customUIColors.schema.json": true,
      "https://esm.sh": true
    },
}
