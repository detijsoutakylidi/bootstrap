[
    // panels — open sidebar views and toggle focus between panels
    // open explorer sidebar
    {
        "key": "cmd+k cmd+e",
        "command": "workbench.view.explorer",
    },
    // open source control sidebar
    {
        "key": "cmd+k cmd+g",
        "command": "workbench.view.scm",
    },
    // open debug sidebar
    {
        "key": "cmd+k cmd+d",
        "command": "workbench.view.debug",
    },
    // open enabled extensions list
    {
        "key": "cmd+k cmd+x",
        "command": "workbench.extensions.action.showEnabledExtensions",
    },
    // show all open editors picker
    {
        "key": "cmd+k cmd+o",
        "command": "workbench.action.showAllEditors",
    },
    // toggle sidebar visibility
    {
        "key": "cmd+k cmd+b",
        "command": "workbench.action.toggleSidebarVisibility"
    },
    // focus editor (escape back from sidebar/terminal)
    {
        "key": "cmd+e",
        "command": "workbench.action.focusActiveEditorGroup",
    },
    // toggle integrated terminal
    {
        "key": "cmd+t",
        "command": "workbench.action.terminal.toggleTerminal",
    },

    // explorer — reveal and toggle file tree
    // reveal current file in explorer, or hide sidebar if already focused
    {
        "key": "cmd+\\",
        "command": "workbench.files.action.showActiveFileInExplorer",
        "when": "editorTextFocus",
    },
    {
        "key": "cmd+\\",
        "command": "workbench.action.toggleSidebarVisibility",
        "when": "explorerViewletFocus",
    },

    // code navigation — symbols, definitions, references
    // go to symbol in current file
    {
        "key": "cmd+r",
        "command": "workbench.action.gotoSymbol",
    },
    // go to symbol across workspace
    {
        "key": "cmd+shift+r",
        "command": "workbench.action.showAllSymbols",
    },
    // find all references (replaces peek definition)
    {
        "key": "alt+f12",
        "command": "-editor.action.peekDefinition",
        "when": "editorHasDefinitionProvider && editorTextFocus && !inReferenceSearchEditor && !isInEmbeddedEditor"
    },
    {
        "key": "alt+f12",
        "command": "editor.action.referenceSearch.trigger",
        "when": "editorHasReferenceProvider && !inReferenceSearchEditor && !isInEmbeddedEditor"
    },

    // editing — quotes, snippets
    // toggle quotes: unbind default cmd+' and rebind to shift+cmd+;
    {
        "key": "cmd+'",
        "command": "-editor.togglequotes"
    },
    {
        "key": "shift+cmd+[Semicolon]",
        "command": "editor.togglequotes"
    },

    // terminal — behavior overrides
    // shift+enter sends escape then enter (run command without newline confirmation)
    {
        "key": "shift+enter",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\u001b\r"
        },
        "when": "terminalFocus"
    },

    // extensions — PHP Namespace Resolver
    // import PHP class under cursor
    {
        "key": "cmd+k cmd+i",
        "command": "namespaceResolver.import",
    },

    // extensions — SFTP
    // diff current file with remote version (replaces default shift+cmd+d debug)
    {
        "key": "shift+cmd+d",
        "command": "-workbench.view.debug",
        "when": "viewContainer.workbench.view.debug.enabled"
    },
    {
        "key": "shift+cmd+d",
        "command": "sftp.diff.activeFile"
    },
]
